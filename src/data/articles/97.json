: 0cm 5.4pt; width: 45pt;\"> <p align=\"center\" class=\"MsoNormal\" style=\"text-align: center;\"><span style=\"font-size: 10pt; font-family: Arial;\">1</span></p> </td> <td width=\"60\" valign=\"top\" style=\"border-style: none solid solid none; border-color: -moz-use-text-color windowtext windowtext -moz-use-text-color; border-width: medium 1pt 1pt medium; padding: 0cm 5.4pt; width: 45pt;\"> <p align=\"center\" class=\"MsoNormal\" style=\"text-align: center;\"><span style=\"font-size: 10pt; font-family: Arial;\">10</span></p> </td> <td width=\"48\" valign=\"top\" style=\"border-style: none solid solid none; border-color: -moz-use-text-color windowtext windowtext -moz-use-text-color; border-width: medium 1pt 1pt medium; padding: 0cm 5.4pt; width: 36pt;\"> <p align=\"center\" class=\"MsoNormal\" style=\"text-align: center;\"><span style=\"font-size: 10pt; font-family: Arial;\">2</span></p> </td> <td width=\"55\" valign=\"top\" style=\"border-style: none solid solid none; border-color: -moz-use-text-color windowtext windowtext -moz-use-text-color; border-width: medium 1pt 1pt medium; padding: 0cm 5.4pt; width: 41.15pt;\"> <p align=\"center\" class=\"MsoNormal\" style=\"text-align: center;\"><span style=\"font-size: 10pt; font-family: Arial;\">0</span></p> </td> </tr> <tr style=\"\"> <td width=\"415\" valign=\"top\" style=\"border-style: none solid solid; border-color: -moz-use-text-color windowtext windowtext; border-width: medium 1pt 1pt; padding: 0cm 5.4pt; width: 311.4pt;\"> <p class=\"MsoNormal\"><span style=\"font-size: 10pt; font-family: Arial;\">2. Образование тотальных синехий</span></p> </td> <td width=\"60\" valign=\"top\" style=\"border-style: none solid solid none; border-color: -moz-use-text-color windowtext windowtext -moz-use-text-color; border-width: medium 1pt 1pt medium; padding: 0cm 5.4pt; width: 45pt;\"> <p align=\"center\" class=\"MsoNormal\" style=\"text-align: center;\"><span style=\"font-size: 10pt; font-family: Arial;\">1</span></p> </td> <td width=\"60\" valign=\"top\" style=\"border-style: none solid solid none; border-color: -moz-use-text-color windowtext windowtext -moz-use-text-color; border-width: medium 1pt 1pt medium; padding: 0cm 5.4pt; width: 45pt;\"> <p align=\"center\" class=\"MsoNormal\" style=\"text-align: center;\"><span style=\"font-size: 10pt; font-family: Arial;\">10</span></p> </td> <td width=\"48\" valign=\"top\" style=\"border-style: none solid solid none; border-color: -moz-use-text-color windowtext windowtext -moz-use-text-color; border-width: medium 1pt 1pt medium; padding: 0cm 5.4pt; width: 36pt;\"> <p align=\"center\" class=\"MsoNormal\" style=\"text-align: center;\"><span style=\"font-size: 10pt; font-family: Arial;\">0</span></p> </td> <td width=\"55\" valign=\"top\" style=\"border-style: none solid solid none; border-color: -moz-use-text-color windowtext windowtext -moz-use-text-color; border-width: medium 1pt 1pt medium; padding: 0cm 5.4pt; width: 41.15pt;\"> <p align=\"center\" class=\"MsoNormal\" style=\"text-align: center;\"><span style=\"font-size: 10pt; font-family: Arial;\">0</span></p> </td> </tr> <tr style=\"\"> <td width=\"415\" valign=\"top\" style=\"border-style: none solid solid; border-color: -moz-use-text-color windowtext windowtext; border-width: medium 1pt 1pt; padding: 0cm 5.4pt; width: 311.4pt;\"> <p class=\"MsoNormal\"><span style=\"font-size: 10pt; font-family: Arial;\">3. Увеальная глаукома</span></p> </td> <td width=\"60\" valign=\"top\" style=\"border-style: none solid solid none; border-color: -moz-use-text-color windowtext windowtext -moz-use-text-color; border-width: medium 1pt 1pt medium; padding: 0cm 5.4pt; width: 45pt;\"> <p align=\"center\" class=\"MsoNormal\" style=\"text-align: center;\"><span style=\"font-size: 10pt; font-family: Arial;\">4</span></p> </td> <td width=\"60\" valign=\"top\" style=\"border-style: none solid solid none; border-color: -moz-use-text-color windowtext windowtext -moz-use-text-color; border-width: medium 1pt 1pt med